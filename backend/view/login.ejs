<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Admin Login</title>
		<style>
			@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&display=swap');
			body {
				font-family: 'Manrope', Arial, sans-serif;
				background: #f3f5f8;
				color: #112138;
				margin: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 100vh;
			}
			.card {
				background: #fff;
				padding: 2rem;
				border-radius: 16px;
				box-shadow: 0 18px 30px rgba(17, 33, 56, 0.12);
				width: min(420px, 90vw);
			}
			.brand {
				display: flex;
				align-items: center;
				gap: 0.9rem;
				margin-bottom: 1.5rem;
			}
			.logo {
				height: auto;
				width: auto;
				border-radius: 0;
				background: transparent;
				display: grid;
				place-items: center;
				box-shadow: none;
				overflow: visible;
			}
			.logo img {
				width: auto;
				height: auto;
				max-width: 140px;
				max-height: 60px;
				object-fit: contain;
				display: block;
			}
			.brand h1 {
				margin: 0;
				font-size: 1.4rem;
				font-weight: 800;
			}
			.brand p {
				margin: 0.25rem 0 0;
				color: #5b677a;
				font-size: 0.9rem;
			}
			h1 {
				margin: 0 0 1rem;
				font-size: 1.2rem;
				color: #112138;
			}
			label {
				display: block;
				font-weight: 700;
				margin-bottom: 0.4rem;
			}
			input {
				width: 100%;
				padding: 0.7rem 0.9rem;
				border-radius: 10px;
				border: 1px solid #dbe4ef;
				margin-bottom: 1rem;
				font-size: 0.95rem;
			}
			button {
				width: 100%;
				padding: 0.8rem 1rem;
				border-radius: 999px;
				border: none;
				background: #7d0916;
				color: #fff;
				font-weight: 700;
				cursor: pointer;
			}
			.helper {
				margin-top: 1rem;
				text-align: center;
				color: #5b677a;
				font-size: 0.9rem;
			}
			.helper a {
				color: #7d0916;
				font-weight: 700;
				text-decoration: none;
			}
			.error {
				color: #b91c1c;
				background: #fee2e2;
				border-radius: 10px;
				padding: 0.6rem 0.8rem;
				margin-bottom: 1rem;
				font-size: 0.9rem;
			}
		</style>
	</head>
	<body>
		<form class="card" method="POST" action="/admin/login">
			<div class="brand">
				<div class="logo"><img src="/assets/photo/chatimg-002.png" alt="Asan" /></div>
				<div>
					<h1>Asan Appliances</h1>
					<p>Admin Login</p>
				</div>
			</div>
			<% if (error) { %>
				<div class="error"><%= error %></div>
			<% } %>
			<label for="username">Username</label>
			<input id="username" name="username" type="text" required />

			<label for="password">Password</label>
			<input id="password" name="password" type="password" required />

			<button type="submit">Sign In</button>
			<p class="helper">
				Need an admin account? <a href="/admin/signup">Create one</a>
			</p>
		</form>
	</body>
</html>

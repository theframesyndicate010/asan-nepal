<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>All Products</title>
		<style>
			@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&display=swap');
			:root {
				--ink: #0f172a;
				--muted: #5b677a;
				--brand: #7d0916;
				--brand-soft: #f8e7ea;
				--surface: #ffffff;
				--line: #e6edf5;
			}
			* {
				box-sizing: border-box;
			}
			body {
				font-family: 'Manrope', Arial, sans-serif;
				background: radial-gradient(circle at top, #ffffff 0%, #f4f6f9 45%, #eef2f6 100%);
				color: var(--ink);
				margin: 0;
				padding: 2.5rem 1.5rem 3.5rem;
			}
			main {
				max-width: 1080px;
				margin: 0 auto;
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}
			.header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1.5rem;
				background: var(--surface);
				padding: 1.75rem 2rem;
				border-radius: 20px;
				box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
				border: 1px solid var(--line);
			}
			.header h1 {
				margin: 0;
				font-size: 1.6rem;
				font-weight: 800;
			}
			.header p {
				margin: 0.2rem 0 0;
				color: var(--muted);
				font-size: 0.95rem;
			}
			.header-actions {
				display: flex;
				gap: 0.8rem;
				flex-wrap: wrap;
			}
			.header-actions a {
				text-decoration: none;
				padding: 0.6rem 1.2rem;
				border-radius: 999px;
				font-weight: 700;
				color: var(--brand);
				border: 1px solid rgba(125, 9, 22, 0.2);
				background: var(--brand-soft);
			}
			.primary {
				background: var(--brand);
				color: #fff;
				border: none;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 320px));
				gap: 1.5rem;
				justify-content: center;
			}
			.card {
				background: var(--surface);
				border-radius: 18px;
				border: 1px solid var(--line);
				box-shadow: 0 16px 30px rgba(15, 23, 42, 0.06);
				padding: 1.2rem;
				display: flex;
				flex-direction: column;
				gap: 0.6rem;
				min-height: 320px;
				max-width: 320px;
			}
			.thumb {
				width: 100%;
				height: 160px;
				border-radius: 14px;
				background: #f3f5f8;
				display: grid;
				place-items: center;
				overflow: hidden;
			}
			.thumb img {
				width: 100%;
				height: 100%;
				object-fit: contain;
			}
			.badge {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				background: var(--brand-soft);
				color: var(--brand);
				padding: 0.25rem 0.7rem;
				border-radius: 999px;
				font-size: 0.75rem;
				font-weight: 700;
			}
			.card h3 {
				margin: 0;
				font-size: 1.1rem;
			}
			.card p {
				margin: 0;
				color: var(--muted);
				font-size: 0.9rem;
			}
			.product-meta {
				display: flex;
				flex-direction: column;
				gap: 0.35rem;
			}
			.card-actions {
				margin-top: auto;
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 0.75rem;
			}
			.card-actions a {
				color: var(--brand);
				font-weight: 700;
				text-decoration: none;
			}
			.delete-btn {
				border: none;
				background: transparent;
				color: #b91c1c;
				font-weight: 700;
				cursor: pointer;
			}
			.empty {
				background: var(--surface);
				border-radius: 18px;
				border: 1px dashed var(--line);
				padding: 2rem;
				text-align: center;
				color: var(--muted);
			}
			@media (max-width: 720px) {
				.header {
					flex-direction: column;
					align-items: flex-start;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<header class="header">
				<div>
					<h1>All Products</h1>
					<p>View the latest catalog and open any item for editing.</p>
				</div>
				<div class="header-actions">
					<a href="/admin">Back to dashboard</a>
					<a class="primary" href="/admin/products/new">Add product</a>
				</div>
			</header>

			<% if (!products || products.length === 0) { %>
				<div class="empty">No products yet. Add one to get started.</div>
			<% } else { %>
				<section class="grid">
					<% products.forEach((product) => { %>
						<article class="card">
							<div class="thumb">
								<% if (product.image) { %>
									<img src="<%= product.image %>" alt="<%= product.name %>" />
								<% } else { %>
									<span class="badge">No Image</span>
								<% } %>
							</div>
							<span class="badge"><%= product.category %></span>
							<div class="product-meta">
								<h3><%= product.name %></h3>
								<p><%= product.spec %></p>
							</div>
							<div class="card-actions">
								<span><%= product.price || 'Price not set' %></span>
								<div>
									<a href="/admin/products/<%= product.id %>/edit">Edit</a>
									<form method="POST" action="/admin/products/<%= product.id %>/delete" style="display: inline;">
										<button class="delete-btn" type="submit" onclick="return confirm('Delete this product?')">Delete</button>
									</form>
								</div>
							</div>
						</article>
					<% }) %>
				</section>
			<% } %>
		</main>
	</body>
</html>

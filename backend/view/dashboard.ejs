<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Admin Dashboard</title>
		<style>
			@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&display=swap');
			:root {
				--ink: #0f172a;
				--muted: #5b677a;
				--brand: #7d0916;
				--brand-soft: #f8e7ea;
				--surface: #ffffff;
				--line: #e6edf5;
			}
			* {
				box-sizing: border-box;
			}
			body {
				font-family: 'Manrope', Arial, sans-serif;
				background: radial-gradient(circle at top, #ffffff 0%, #f4f6f9 45%, #eef2f6 100%);
				color: var(--ink);
				margin: 0;
				padding: 2.5rem 1.5rem 3.5rem;
			}
			main {
				max-width: 980px;
				margin: 0 auto;
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}
			.header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1.5rem;
				background: var(--surface);
				padding: 1.75rem 2rem;
				border-radius: 20px;
				box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
				border: 1px solid var(--line);
			}
			.brand {
				display: flex;
				align-items: center;
				gap: 1rem;
			}
			.logo {
				height: auto;
				width: auto;
				border-radius: 0;
				background: transparent;
				display: grid;
				place-items: center;
				box-shadow: none;
				overflow: visible;
			}
			.logo img {
				width: auto;
				height: auto;
				max-width: 160px;
				max-height: 64px;
				object-fit: contain;
				display: block;
			}
			.brand h1 {
				margin: 0;
				font-size: 1.6rem;
				font-weight: 800;
			}
			.brand p {
				margin: 0.2rem 0 0;
				color: var(--muted);
				font-size: 0.95rem;
			}
			.user-chip {
				background: var(--brand-soft);
				color: var(--brand);
				padding: 0.65rem 1.2rem;
				border-radius: 999px;
				font-weight: 700;
				font-size: 0.95rem;
			}
			.panel {
				background: var(--surface);
				border-radius: 20px;
				padding: 1.75rem 2rem;
				border: 1px solid var(--line);
				box-shadow: 0 20px 35px rgba(15, 23, 42, 0.06);
			}
			.panel h2 {
				margin: 0 0 0.6rem;
				font-size: 1.3rem;
			}
			.panel p {
				margin: 0;
				color: var(--muted);
			}
			.actions {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1.2rem;
				margin-top: 1.5rem;
			}
			.card-link {
				display: flex;
				flex-direction: column;
				gap: 0.6rem;
				padding: 1.2rem 1.4rem;
				border-radius: 16px;
				border: 1px solid var(--line);
				text-decoration: none;
				color: var(--ink);
				background: #fbfcfe;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.card-link span {
				font-weight: 700;
				font-size: 1.05rem;
			}
			.card-link small {
				color: var(--muted);
				font-size: 0.9rem;
			}
			.card-link:hover {
				transform: translateY(-3px);
				box-shadow: 0 16px 30px rgba(15, 23, 42, 0.08);
			}
			.primary {
				border: 1px solid rgba(125, 9, 22, 0.2);
				background: linear-gradient(120deg, #fff6f7, #ffffff 60%);
			}
			.primary span {
				color: var(--brand);
			}
			.footer {
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				flex-wrap: wrap;
				color: var(--muted);
				font-size: 0.9rem;
			}
			.footer a {
				color: var(--brand);
				font-weight: 700;
				text-decoration: none;
			}
			@media (max-width: 720px) {
				.header {
					flex-direction: column;
					align-items: flex-start;
				}
				.user-chip {
					align-self: flex-start;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<header class="header">
				<div class="brand">
					<div class="logo"><img src="/assets/photo/chatimg-002.png" alt="Asan" /></div>
					<div>
						<h1>Asan Appliances</h1>
						<p>Admin Control Center</p>
					</div>
				</div>
				<div class="user-chip">Signed in as <%= username %></div>
			</header>

			<section class="panel">
				<h2>Welcome back, <%= username %></h2>
				<p>Keep the catalog updated and monitor new products from this dashboard.</p>
				<div class="actions">
					<a class="card-link primary" href="/admin/products/new">
						<span>Add a new product</span>
						<small>Upload images, pricing, and availability</small>
					</a>
					<a class="card-link" href="/admin/products">
						<span>See all products</span>
						<small>View the full catalog and edit items</small>
					</a>
				</div>
			</section>

			<div class="footer">
				<div>Asan Appliances • Admin Portal</div>
				<a href="/admin/logout">Sign out</a>
			</div>
		</main>
	</body>
</html>

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Add Product</title>
		<style>
			body {
				font-family: Arial, sans-serif;
				background: #f3f5f8;
				color: #112138;
				margin: 0;
				padding: 2rem;
			}
			.wrap {
				max-width: 760px;
				margin: 0 auto;
				background: #fff;
				padding: 2rem;
				border-radius: 16px;
				box-shadow: 0 18px 30px rgba(17, 33, 56, 0.12);
			}
			label {
				display: block;
				font-weight: 700;
				margin-bottom: 0.4rem;
			}
			input,
			textarea,
			select {
				width: 100%;
				padding: 0.7rem 0.9rem;
				border-radius: 10px;
				border: 1px solid #dbe4ef;
				margin-bottom: 1rem;
				font-size: 0.95rem;
			}
			textarea {
				min-height: 90px;
			}
			button {
				width: 100%;
				padding: 0.8rem 1rem;
				border-radius: 999px;
				border: none;
				background: #7d0916;
				color: #fff;
				font-weight: 700;
				cursor: pointer;
			}
			.notice {
				border-radius: 10px;
				padding: 0.6rem 0.8rem;
				margin-bottom: 1rem;
				font-size: 0.9rem;
			}
			.error {
				color: #b91c1c;
				background: #fee2e2;
			}
			.success {
				color: #166534;
				background: #dcfce7;
			}
			.actions {
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1rem;
			}
			.actions a {
				color: #7d0916;
				font-weight: 700;
				text-decoration: none;
			}
		</style>
	</head>
	<body>
		<div class="wrap">
			<div class="actions">
				<a href="/admin">Back to dashboard</a>
				<a href="/admin/logout">Log out</a>
			</div>

			<h1>Add Product</h1>
			<% if (error) { %>
				<div class="notice error"><%= error %></div>
			<% } %>
			<% if (success) { %>
				<div class="notice success"><%= success %></div>
			<% } %>

			<form method="POST" action="/admin/products" enctype="multipart/form-data">
				<label for="name">Product Name</label>
				<input id="name" name="name" type="text" required />

				<label for="category">Category</label>
				<select id="category" name="category" required>
					<option value="" disabled selected>Select a category</option>
					<% categories.forEach(function(cat) { %>
						<option value="<%= cat %>"><%= cat %></option>
					<% }) %>
				</select>

				<label for="spec">Specification</label>
				<textarea id="spec" name="spec" required></textarea>

				<label for="price">Price</label>
				<input id="price" name="price" type="number" min="0" step="0.01" placeholder="12000" />

				<label for="image">Product Photo</label>
				<input id="image" name="image" type="file" accept="image/*" />

				<button type="submit">Save Product</button>
			</form>
		</div>
	</body>
</html>
